{
  "pluginAlias": "SmartThingsKM81",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Samsung 기기(구형 에어컨 / 신형 에어컨 / 세탁기·건조기)를 하나의 플랫폼으로 통합 관리합니다. SmartThings를 사용하는 장치(신형 AC / 세탁기 / 건조기)가 하나라도 있으면 Client ID/Secret/Redirect URI가 필요합니다.",
  "schema": {
    "type": "object",
    "properties": {
      "name": { "title": "플랫폼 이름", "type": "string", "default": "SmartThings KM81", "required": true },
      "clientId": { "title": "SmartThings Client ID", "type": "string", "description": "SmartThings Developer Workspace에서 발급받은 Client ID (SmartThings 기반 장치를 사용할 때만 필수)" },
      "clientSecret": { "title": "SmartThings Client Secret", "type": "string" },
      "redirectUri": { "title": "Redirect URI", "type": "string", "default": "https://myhome.example.com", "description": "SmartThings에 등록한 https Redirect URI (포트 없이 도메인만, 예: https://myhome.example.com). 외부 443 포트가 리버스 프록시를 거쳐 내부 http://<homebridge_ip>:8999 로 전달되어야 합니다." },
      "temperatureMin": { "title": "기본 목표온도 최소값(℃) — SmartAC 공용", "type": "number", "default": 18 },
      "temperatureMax": { "title": "기본 목표온도 최대값(℃) — SmartAC 공용", "type": "number", "default": 30 },
      "temperatureStep": { "title": "기본 목표온도 스텝(℃) — SmartAC 공용", "type": "number", "default": 1 },
      "devices": {
        "type": "array",
        "title": "장치 목록",
        "default": [],
        "items": {
          "type": "object",
          "properties": {
            "deviceType": {
              "title": "장치 종류",
              "type": "string",
              "default": "smartAc",
              "oneOf": [
                { "title": "구형 에어컨 (Samsung Legacy, TLSv1 직접통신)", "enum": ["legacyAc"] },
                { "title": "신형 에어컨 (SmartThings)", "enum": ["smartAc"] },
                { "title": "세탁기 (SmartThings)", "enum": ["washer"] },
                { "title": "건조기 (SmartThings)", "enum": ["dryer"] }
              ],
              "required": true
            },

            "name": { "title": "[구형 AC] 액세서리 이름", "type": "string", "description": "홈 앱에 표시될 이름" },
            "ip": { "title": "[구형 AC] 에어컨 IP 주소", "type": "string", "format": "ipv4" },
            "token": { "title": "[구형 AC] 인증 토큰", "type": "string" },
            "deviceIndex": { "title": "[구형 AC] 장치 인덱스 (읽기)", "type": "integer", "default": 0 },
            "setDeviceIndex": { "title": "[구형 AC] 장치 인덱스 (쓰기)", "type": "integer" },
            "pollingInterval": { "title": "[AC 공통] 상태 폴링 간격 (초)", "type": "integer", "description": "구형 AC: 비워두면 폴링 안 함. 신형 AC: 비워두면 30초로 자동 폴링 (SmartThings 앱/리모컨에서 변경한 상태를 HomeKit에 반영). 신형 AC 최소 10초까지 허용되며 더 낮은 값은 10초로 올림됩니다. 0을 입력하면 신형 AC 폴링을 끕니다." },
            "timeout": { "title": "[구형 AC] 요청 시간 초과 (ms)", "type": "integer", "default": 5000 },
            "cacheDuration": { "title": "[구형 AC] 캐시 유지 시간 (ms)", "type": "integer", "default": 30000 },
            "certPath": { "title": "[구형 AC] 인증서 경로 (선택)", "type": "string", "description": "비워두면 패키지에 포함된 cert/cert.pem을 사용합니다." },
            "keyPath": { "title": "[구형 AC] 키 파일 경로 (선택)", "type": "string" },
            "manufacturer": { "title": "[구형 AC] 제조사", "type": "string", "default": "Samsung" },
            "debug": { "title": "[구형 AC] 상세 로그", "type": "boolean", "default": false },
            "minTemp": { "title": "[구형 AC] 목표온도 최소값 (°C)", "type": "integer", "default": 18 },
            "maxTemp": { "title": "[구형 AC] 목표온도 최대값 (°C)", "type": "integer", "default": 30 },

            "hkCoolMode": {
              "title": "[구형 AC] HomeKit '냉방(COOL)' 전송 모드",
              "type": "string",
              "default": "Cool",
              "oneOf": [
                { "title": "냉방 (Cool) 명령", "enum": ["Cool"] },
                { "title": "냉방청정 (CoolClean) 명령", "enum": ["CoolClean"] },
                { "title": "제습 (Dry) 명령", "enum": ["Dry"] },
                { "title": "제습청정 (DryClean) 명령", "enum": ["DryClean"] }
              ],
              "description": "HomeKit에서 '냉방' 버튼을 누를 때 또는 모드 변경 시 실제 AC에 보낼 모드입니다."
            },
            "legacySwingBinding": {
              "title": "[구형 AC] 스윙(Swing) 토글 ↔ 기능",
              "type": "string",
              "default": "comfort",
              "oneOf": [
                { "title": "무풍 (Comfort)", "enum": ["comfort"] },
                { "title": "상하 바람 (Wind)", "enum": ["wind"] },
                { "title": "사용 안 함", "enum": ["none"] }
              ],
              "description": "HomeKit 스윙 토글이 어떤 실제 기능에 연결될지 선택합니다. '사용 안 함'을 선택하면 HomeKit 타일에서 스윙 버튼이 사라집니다."
            },
            "legacyLockBinding": {
              "title": "[구형 AC] 어린이 보호용 잠금장치 ↔ 기능",
              "type": "string",
              "default": "autoClean",
              "oneOf": [
                { "title": "자동건조 (AutoClean)", "enum": ["autoClean"] },
                { "title": "사용 안 함", "enum": ["none"] }
              ],
              "description": "HomeKit 잠금 토글이 어떤 실제 기능에 연결될지 선택합니다. '사용 안 함'을 선택하면 HomeKit 잠금 토글이 사라집니다."
            },
            "legacyOnGuardMs": {
              "title": "[구형 AC] 전원 ON 직후 보호 시간 (ms)",
              "type": "integer",
              "default": 2000,
              "minimum": 0,
              "maximum": 10000,
              "description": "전원을 켠 직후 이 시간 동안은 다른 명령(모드/온도/스윙/잠금)을 실제 기기에 보내지 않습니다. 구형 펌웨어가 동시 명령을 놓치는 것을 막기 위함입니다. 0으로 두면 보호를 끕니다."
            },
            "legacyOnGuardStrategy": {
              "title": "[구형 AC] ON 보호 중 다른 명령 처리",
              "type": "string",
              "default": "drop",
              "oneOf": [
                { "title": "무시 (드롭) — 손으로 켜고 사용", "enum": ["drop"] },
                { "title": "큐 — 자동화/Siri 일괄 동작", "enum": ["queue"] }
              ],
              "description": "ON 명령 직후 들어오는 모드/온도/스윙/잠금 명령을 어떻게 다룰지 선택합니다. 일반적으로 손으로 켜는 사용 패턴이면 '무시'가 안전하고, HomeKit 자동화로 '켜고 26도로' 같은 일괄 동작을 쓴다면 '큐'를 권장합니다."
            },

            "deviceLabel": { "title": "[SmartThings] 장치 이름 (SmartThings 레이블)", "type": "string", "description": "SmartThings 앱에 등록된 이름과 정확히 일치해야 합니다." },
            "model": { "title": "모델명 (선택)", "type": "string" },
            "serialNumber": { "title": "일련번호 (선택)", "type": "string" },

            "coolModeCommand": {
              "title": "[신형 AC] HomeKit '냉방(COOL)' 전송 모드",
              "type": "string",
              "default": "cool",
              "oneOf": [
                { "title": "냉방 (Cool) 명령", "enum": ["cool"] },
                { "title": "냉방청정 (CoolClean) 명령", "enum": ["coolClean"] },
                { "title": "제습 (Dry) 명령", "enum": ["dry"] },
                { "title": "제습청정 (DryClean) 명령", "enum": ["dryClean"] }
              ]
            },
            "swingBinding": {
              "title": "[신형 AC] 스윙(Swing) 토글 ↔ 기능",
              "type": "string",
              "default": "windFree",
              "oneOf": [
                { "title": "무풍 (WindFree)", "enum": ["windFree"] },
                { "title": "사용 안 함", "enum": ["none"] }
              ]
            },
            "lockBinding": {
              "title": "[신형 AC] 어린이 보호용 잠금장치 ↔ 기능",
              "type": "string",
              "default": "autoClean",
              "oneOf": [
                { "title": "자동건조 (Auto Clean)", "enum": ["autoClean"] },
                { "title": "사용 안 함", "enum": ["none"] }
              ]
            },
            "exposeWindFreeSwitch": { "title": "[신형 AC] 무풍 별도 스위치 노출", "type": "boolean", "default": false },
            "exposeAutoCleanSwitch": { "title": "[신형 AC] 자동건조 별도 스위치 노출", "type": "boolean", "default": false },
            "temperatureMin": { "title": "[신형 AC] 목표온도 최소값 (°C)", "type": "number" },
            "temperatureMax": { "title": "[신형 AC] 목표온도 최대값 (°C)", "type": "number" },
            "temperatureStep": { "title": "[신형 AC] 목표온도 스텝 (°C)", "type": "number" },

            "enableNotificationSensor": { "title": "[세탁/건조기] 종료 알림 센서 활성화", "type": "boolean", "default": false, "description": "운전 종료 시 iOS 푸시 알림을 받기 위한 가상 모션 센서를 노출합니다. (HomeKit 자동화 트리거로도 사용 가능)" },
            "sensorName": { "title": "[세탁/건조기] 종료 알림 센서 이름", "type": "string", "description": "HomeKit에 표시될 모션 센서 이름. 비워두면 '{장치명} 종료알림'으로 자동 생성됩니다." },
            "sensorPollInterval": { "title": "[세탁/건조기] 상태 폴링 간격(초)", "type": "integer", "default": 30, "minimum": 5, "description": "운전 종료를 감지하기 위해 SmartThings 상태를 확인하는 주기입니다." }
          },
          "required": ["deviceType"]
        }
      }
    },
    "required": ["name", "devices"]
  },

  "layout": [
    "name",
    {
      "type": "fieldset",
      "title": "SmartThings 인증 (신형 AC / 세탁기 / 건조기 사용 시 필수)",
      "expandable": true, "expanded": false,
      "items": [
        { "type": "help", "help": "1) SmartThings CLI(<code>npm i -g @smartthings/cli</code>) + <code>smartthings apps:create</code> 로 OAuth-In 앱 생성<br>2) Scope: <code>r:devices:*</code> <code>w:devices:*</code> <code>x:devices:*</code><br>3) Redirect URI는 <b>https 도메인만</b> (포트 X). 예: <code>https://myhome.example.com</code><br>4) 외부 443 → 내부 <code>&lt;homebridge_ip&gt;:8999</code> 로 리버스 프록시 필요<br>5) 토큰 파일: <code>smartthings_km81_token.json</code> (통합)" },
        "clientId", "clientSecret", "redirectUri"
      ]
    },
    {
      "type": "fieldset",
      "title": "SmartAC 공용 기본값 (개별 장치에서 덮어쓸 수 있음)",
      "expandable": true, "expanded": false,
      "items": ["temperatureMin", "temperatureMax", "temperatureStep"]
    },
    {
      "key": "devices",
      "type": "tabarray",
      "title": "{{ value.name || value.deviceLabel || ('Device ' + ($index + 1)) }}",
      "expandable": false,
      "items": [
        "devices[].deviceType",

        { "key": "devices[].name",            "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].ip",              "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].token",           "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].deviceIndex",     "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].setDeviceIndex",  "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].pollingInterval", "condition": { "functionBody": "return model.devices[arrayIndices[0]] && (model.devices[arrayIndices[0]].deviceType==='legacyAc' || model.devices[arrayIndices[0]].deviceType==='smartAc');" } },
        { "key": "devices[].timeout",         "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].cacheDuration",   "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].certPath",        "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].keyPath",         "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].manufacturer",    "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].debug",           "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },

        { "key": "devices[].deviceLabel",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['smartAc','washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType);" } },

        { "key": "devices[].model",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['legacyAc','smartAc','washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType);" } },
        { "key": "devices[].serialNumber",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['legacyAc','smartAc','washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType);" } },

        { "key": "devices[].hkCoolMode", "type": "select", "required": true,
          "titleMap": [
            { "value": "Cool",      "name": "냉방 (Cool) 명령" },
            { "value": "CoolClean", "name": "냉방청정 (CoolClean) 명령" },
            { "value": "Dry",       "name": "제습 (Dry) 명령" },
            { "value": "DryClean",  "name": "제습청정 (DryClean) 명령" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].legacySwingBinding", "type": "select", "required": true,
          "titleMap": [
            { "value": "comfort", "name": "무풍 (Comfort)" },
            { "value": "wind",    "name": "상하 바람 (Wind)" },
            { "value": "none",    "name": "사용 안 함" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].legacyLockBinding", "type": "select", "required": true,
          "titleMap": [
            { "value": "autoClean", "name": "자동건조 (AutoClean)" },
            { "value": "none",      "name": "사용 안 함" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].legacyOnGuardMs",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].legacyOnGuardStrategy", "type": "select",
          "titleMap": [
            { "value": "drop",  "name": "무시 (드롭)" },
            { "value": "queue", "name": "큐 (보호 후 한 번에 전송)" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },

        { "key": "devices[].coolModeCommand", "type": "select", "required": true,
          "titleMap": [
            { "value": "cool",      "name": "냉방 (Cool) 명령" },
            { "value": "coolClean", "name": "냉방청정 (CoolClean) 명령" },
            { "value": "dry",       "name": "제습 (Dry) 명령" },
            { "value": "dryClean",  "name": "제습청정 (DryClean) 명령" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].swingBinding", "type": "select", "required": true,
          "titleMap": [
            { "value": "windFree", "name": "무풍 (WindFree)" },
            { "value": "none",     "name": "사용 안 함" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].lockBinding", "type": "select", "required": true,
          "titleMap": [
            { "value": "autoClean", "name": "자동건조 (Auto Clean)" },
            { "value": "none",      "name": "사용 안 함" }
          ],
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].exposeWindFreeSwitch", "type": "checkbox",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].exposeAutoCleanSwitch", "type": "checkbox",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },

        { "key": "devices[].enableNotificationSensor",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType);" } },
        { "key": "devices[].sensorName",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType) && model.devices[arrayIndices[0]].enableNotificationSensor;" } },
        { "key": "devices[].sensorPollInterval",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && ['washer','dryer'].includes(model.devices[arrayIndices[0]].deviceType) && model.devices[arrayIndices[0]].enableNotificationSensor;" } },

        { "key": "devices[].minTemp",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },
        { "key": "devices[].maxTemp",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='legacyAc';" } },

        { "key": "devices[].temperatureMin",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].temperatureMax",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } },
        { "key": "devices[].temperatureStep",
          "condition": { "functionBody": "return model.devices[arrayIndices[0]] && model.devices[arrayIndices[0]].deviceType==='smartAc';" } }
      ]
    }
  ]
}
